<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Network Book Club</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibraryProject.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom box-shadow mb-3" style="background-color: #33C198">
    <div class="container-fluid">
        <img class="logo" src="~/css/pics/LogoWindow.png"/>
                <a class="navbar-brand text-light" asp-area="" asp-controller="Home" asp-action="Accueil"><b>Network Book Club</b></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
            <ul class="navbar-nav ml-auto">
                <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Accueil"><b>Accueil</b></a>
                </li>
                <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Livres" asp-action="Index"><b>Livres</b></a>
                </li>
                <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Ecrivains"><b>Ecrivains</b></a>
                </li>
                <li class="nav-item" style="margin-left:850px">
                            <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Connexion"><b>Connexion</b></a>
                </li>
                        <li class="nav-item" style="margin-left:40px">
                            <a class="nav-link text-light" asp-area="" asp-controller="Paniers" asp-action="Panier">
                        <i class="fas fa-shopping-cart"></i>
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted" style="text-align: center">
        <div class="container">
            &copy; 2023 - Network Book Club - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
<style>
    .logo {
        width: 40px;
        height: 50px;
        margin-top:-8px;
        margin-left:-3px;
    }
  
</style>