@{
    ViewData["Title"] = "Home Page";
}

<div class="container " style="display: block; text-align: center;">

    <div class="nav" style="display: flex;">
        <!----------------------------------  Barre de recherche -------------------------------------------------->
        <div class="text-center">
            <input name="query" aria-label="search" autocomplete="off" class="search-field" id="sm"
                   placeholder="Rechercher par titre, auteur, série" type="search" value="" />
        </div>
        <div>
            <button style="background-color:#33C198; border-color:#33C198;">Chercher</button>
        </div>
    </div>


    <!----------------------------------  Liste des livres -------------------------------------------------->
    <div class="card" style="display:block; margin-right:90px">
        <div class="book" style="display: flex;">
            <a class="Infos_complets margin decoration" href="@Url.Action("EcrivainInfo", "Home")">
                <!--  Image --->
                <div class="img flex-container">
                    <img style="margin:10px 0px 10px 0px" class="cover-image height1 notranslate_alt book-image" alt="Le Quatrième homme eBook by Lisa Gardner"
                         src="https://cdn.kobo.com/book-images/dd078d1f-6396-4178-8e24-b7b98ddae930/140/215/60/False/le-quatrieme-homme.jpg"
                         data-lazy="//cdn.kobo.com/book-images/dd078d1f-6396-4178-8e24-b7b98ddae930/140/215/60/False/le-quatrieme-homme.jpg">
                </div>
            </a>
            <div class="InfoSupp" style="display:block">
                <!--  Infos de l'auteur --->
                <div class="Ecdetails" style="display:flex;text-align: justify;margin:20px 30px 10px 0px;">
                    <div class="name x">Nom et prénom</div>
                    <div class="dn x">Date de naissance</div>
                    <div class="dd x">Date de décès</div>
                    <div class="pays x">Pays d'origine</div>
                </div>
                <!-- Qlqs ouvrages de l'auteur' -->
                <div class="ouvrages" style="display:flex;margin:20px 30px 10px 0px;">
                    <div class="ouvrages" style="display:flex">
                        <p>Quelques ouvrages :</p>
                        <div style="display:block">
                            <a href="" class="ouvrg">1er ouvrage</a>
                            <a href="" class="ouvrg">2eme ouvrage</a>
                            <a href="" class="ouvrg">3eme ouvrage</a>
                        </div>
                    </div>
                </div>
            </div>    
        </div>
    </div>
</div>




<style>
    .nav {
        margin-left: 150px;
    }

    .container {
        margin-left: 100px;
    }

    .margin {
        margin-left: 30px;
        margin-right: 30px;
    }

    a {
        margin-bottom: 10px;
    }
    .card{
        border: 1px solid #33C198;
        padding: 10px;
        box-shadow: 0 10px 10px rgba(51, 193, 152, 0.5);
    }
    input {
        padding: 5px;
        width: 800px;
        margin-bottom: 70px;
        margin-top: 10px;
        border-radius: 10px;
    }

    button {
        margin-top: 12px;
        padding: 4px;
        border-radius: 8px;
        margin-left: 10px;
        background-color: #33C198;
        border-color: #33C198;
    }
    .x{
        margin-right: 50px;
    }

    .ouvrg{
        margin-left:10px;
    }
    .decoration {
        text-decoration: none;
    }
</style>



